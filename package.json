{
  "name": "apurv-personal-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint --config config/eslint.config.mjs .",
    "newrelic:alerts": "node scripts/setup-newrelic-alerts.mjs",
    "start": "next start",
    "clean": "rm -rf .next .vercel test-results tsconfig.tsbuildinfo",
    "test": "pnpm test:all",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:api && pnpm test:component && pnpm test:smoke && pnpm test:e2e && pnpm test:a11y",
    "test:unit": "vitest --config config/vitest.config.ts run src/tests/unit",
    "test:integration": "vitest --config config/vitest.config.ts run src/tests/integration",
    "test:api": "vitest --config config/vitest.config.ts run src/tests/api",
    "test:component": "vitest --config config/vitest.config.ts run src/tests/components",
    "test:smoke": "playwright test --config config/playwright.config.ts src/tests/e2e/smoke.spec.ts",
    "test:e2e": "playwright test --config config/playwright.config.ts src/tests/e2e/navigation.spec.ts src/tests/e2e/contact.spec.ts",
    "test:a11y": "playwright test --config config/playwright.config.ts src/tests/e2e/a11y.spec.ts"
  },
  "dependencies": {
    "@newrelic/browser-agent": "^1.312.1",
    "@next/third-parties": "^16.1.7",
    "@newrelic/browser-agent": "^1.312.1",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "newrelic": "^13.18.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "jsdom": "^28.1.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev"
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Next.js: debug full stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "if lsof -ti:3000 > /dev/null 2>&1; then echo 'Port 3000 in use, cleaning up...'; lsof -ti:3000 | xargs kill -9 2>/dev/null; rm -rf .next/dev/lock 2>/dev/null; sleep 1; fi; pnpm dev",
      "serverReadyAction": {
        "pattern": "Ready in",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      }
    }
  ]
}
